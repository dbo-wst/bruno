meta {
  name: Portfolio
  type: http
  seq: 1
}

get {
  url: https://{{host}}:{{port}}/api/rest/v78
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Host: api.tick-ts.de
}

body:json {
  {
    "type": "portfolio",
    "token": "tbmx_access_password {\"username\":\"{{username}}\",\"password\":\"{{password}}\"}",
    "accountId": "H013"
  }
}

settings {
  encodeUrl: false
  timeout: 0
}
